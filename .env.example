# ─────────────────────────────────────────────────────────
# Custom Signet Configuration
# ─────────────────────────────────────────────────────────

# ── Reverse Proxy ────────────────────────────────────────
# For IP-only access (HTTP):
SITE_ADDRESS=:80
SITE_PORT=80
FAUCET_ADDRESS=:3000
FAUCET_PORT=3000
MEMPOOL_ADDRESS=:8080
MEMPOOL_PORT=8080

# For a domain with automatic HTTPS (uncomment and edit):
# SITE_ADDRESS=signet.yourdomain.com
# FAUCET_ADDRESS=faucet.signet.yourdomain.com
# MEMPOOL_ADDRESS=mempool.signet.yourdomain.com

# ── Control Panel Auth ───────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=admin

# ── Bitcoin RPC ──────────────────────────────────────────
BITCOIN_RPC_USER=signet
BITCOIN_RPC_PASS=signetpass

# ── Faucet ───────────────────────────────────────────────
FAUCET_MAX_AMOUNT=1
# Mempool URL for tx links in faucet UI (leave empty for default hostname:8080):
# MEMPOOL_URL=https://mempool.signet.yourdomain.com
